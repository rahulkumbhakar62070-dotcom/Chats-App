<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WhatsApp Chats</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>

    <div class="container">

        <h1>💬 All Chats</h1>
        <p class="subtitle">All Messages in One Place</p>
        <!-- part-5  ME BUTTON ADD KIYE -->
        <form method="get" action="/chats/new">
            <button>➕ New Chat</button>
        </form>


        <% for(let chat of chats) { %>

            <div class="chat">

                <div class="chat-header">
                    <span class="from">👤 <%= chat.from %></span>
                    <span class="to">➡ <%= chat.to %></span>
                </div>

                <div class="msg">
                    <%= chat.msg %>
                </div>

                <!-- added time in part-6 -->
                <div class="chat-info">
                    <span>🕒 <%= chat.created_at.toString().split(" ")[4] %></span>
        <span>📅 <%= chat.created_at.toString().split(" ").slice(0,4).join(" ") %></span>
    </div>

                <div class=" chat-footer">
                            Message sent successfully ✅
                </div>

                <!-- Edit Button -->
                 <div class="chat-actions">
                <form method="GET" action="/chats/<%= chat._id %>/edit">
                    <button class="edit-btn">✏️ Edit</button>
                    </div>

                </form>

    <!-- Delete Button -->
     <div class="chat-actions1">
    <form method="POST" action="/chats/<%= chat._id %>?_method=DELETE"
         onsubmit="return confirmDelete()"
         >
        <button type="submit" class="delete-btn">🗑 Delete</button>
     </div>
    </form>

           </div>

            <% } %>

            <script>

function confirmDelete() {

    return confirm("⚠️ Are you sure you want to delete this chat?");

}

</script>
    </div>

</body>

</html>